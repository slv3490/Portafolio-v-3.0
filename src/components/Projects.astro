        link: "https://legendary-beijinho-e02149.netlify.app/",
        github: "https://github.com/slv3490/FrontendStore",
        imageJPG: "/images/proyects/jpg/frontendstore.jpg",
        imageWebp: "/images/proyects/webp/frontendstore.webp",
        tags: [TAGS.HTML, TAGS.CSS]
    },
    {
        title: "Diseño y Desarrollo Web Freelance 💻",
        description: "Diseño y Desarrollo Web Freelance es mi primera página web, creada para presentar mis servicios como diseñador y desarrollador web independiente.",
        link: "https://regal-swan-3fffe1.netlify.app/",
        github: "https://github.com/slv3490/FreelanceSite",
        imageJPG: "/images/proyects/jpg/diseñoydesarrolloweb.jpg",
        imageWebp: "/images/proyects/webp/diseñoydesarrolloweb.webp",
        tags: [TAGS.HTML, TAGS.CSS]
    }
