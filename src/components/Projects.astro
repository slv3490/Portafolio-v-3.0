---
import GitHub from "../Icons/GitHub.astro"
import Preview from "../Icons/Preview.astro"
import HTMLIcon from "../Icons/HTML.astro"
import CSSIcon from "../Icons/CSS.astro"
import JavascriptIcon from "../Icons/JavaScript.astro"
import PHPIcon from "../Icons/PHP.astro"
import Laravel from "../Icons/Laravel.astro"
import { number } from "astro:schema"

const TAGS = {
    HTML: {
        name: "HTML",
        class: "bg-orange-950 text-white",
        icon: HTMLIcon,
    },
    CSS: {
        name: "CSS",
        class: "bg-blue-950 text-white",
        icon: CSSIcon,
    },
    JavaScript: {
        name: "JavaScript",
        class: "bg-yellow-300/30 text-white",
        icon: JavascriptIcon,
    },
    PHP: {
        name: "PHP",
        class: "bg-[#7377AE]/50 text-white",
        icon: PHPIcon,
    },
    Laravel: {
        name: "Laravel",
        class: "bg-[#FF2F20]/30 text-white",
        icon: Laravel,
    }
}


