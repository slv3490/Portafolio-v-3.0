---
import '../styles/global.css'
import '@fontsource/poppins';
import '@fontsource/roboto';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo-ls.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Open Graph -->
		<meta property="og:type" content="website">
		<meta property="og:title" content="Portafolio Leonel Enrique Silvera">
		<meta property="og:description" content="Portafolio de Leonel Silvera, desarrollador web con preferencias hacia el back-end, con conocimientos sólidos en las tecnologías HTML5, CSS3, JavaScript, PHP y Laravel.">
		<meta property="og:image" content="https://i.postimg.cc/4xZf4qxT/front-page-portfolio-3.png">
		<meta property="og:image:alt" content="Imagen principal de la pagina web de Leonel Silvera.">

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image">
		<meta property="twitter:domain" content="silveraleonel.tech">
		<meta name="twitter:title" content="Portafolio Leonel Enrique Silvera">
		<meta name="twitter:description" content="Portafolio de Leonel Silvera, desarrollador web con preferencias hacia el back-end, con conocimientos sólidos en las tecnologías HTML5, CSS3, JavaScript, PHP y Laravel.">
		<meta name="twitter:image" content="https://i.postimg.cc/4xZf4qxT/front-page-portfolio-3.png">
		
		<link rel="cannonical" href="https://silveraleonel.tech/">

	</head>
	<body class="relative">

		<div class="absolute top-0 z-[-2] h-full w-full bg-[#010409] bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(195,82,255,0.2),rgba(255,255,255,0))]"></div>

		<slot />

		<Footer />
	</body>
</html>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		scroll-behavior: smooth;
	}

	h1, h2, h3, h4 {
		font-family: 'Poppins', sans-serif;
	}
	p {
		font-family: 'Roboto', sans-serif;
	}

	:root {
		color-scheme: light dark;
	}
</style>
